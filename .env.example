# eroasmr-scraper configuration
# Copy this file to .env and customize

# HTTP Configuration
# EROASMR_HTTP__BASE_URL=https://eroasmr.com
# EROASMR_HTTP__DELAY_MIN=1.5
# EROASMR_HTTP__DELAY_MAX=3.0
# EROASMR_HTTP__MAX_CONNECTIONS=3
# EROASMR_HTTP__MAX_RETRIES=3

# Database Configuration
# EROASMR_DB__PATH=data/videos.db
# EROASMR_DB__BATCH_SIZE=100

# Scraper Configuration
# EROASMR_SCRAPER__START_PAGE=1
# EROASMR_SCRAPER__END_PAGE=
# EROASMR_SCRAPER__SAVE_INTERVAL=10
# EROASMR_SCRAPER__REVERSE=false

# Telegram Upload Service Configuration
# Get tenant_id from the upload service after creating a tenant
# EROASMR_TELEGRAM__UPLOAD_SERVICE_URL=http://localhost:8000
# EROASMR_TELEGRAM__TENANT_ID=your-tenant-id-here
# EROASMR_TELEGRAM__CAPTION_TEMPLATE={title}
# EROASMR_TELEGRAM__PARSE_MODE=HTML

# Logging
# LOG_LEVEL=INFO
